{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", "tsconfig.base.json"],
  "globalEnv": [
    "NODE_ENV",
    "LOG_LEVEL",
    "CORS_ORIGIN",
    "API_PORT",
    "AGENT_RUNTIME_PORT",
    "EVENT_WORKER_PORT",
    "TXLINE_HEALTH_PORT",
    "DATABASE_URL",
    "REDIS_URL",
    "TXLINE_API_HOST",
    "TXLINE_GUEST_JWT",
    "TXLINE_API_TOKEN",
    "TXLINE_SERVICE_LEVEL",
    "TXLINE_NETWORK",
    "TXLINE_BASE_URL",
    "SOLANA_RPC_URL",
    "SOLANA_WALLET_PRIVATE_KEY",
    "JWT_SECRET",
    "OPENAI_API_KEY",
    "ANTHROPIC_API_KEY",
    "DEEPSEEK_API_KEY",
    "GEMINI_API_KEY",
    "GROK_API_KEY",
    "QWEN_API_KEY",
    "LLAMA_API_KEY",
    "ENABLE_LLM",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_WS_URL",
    "MOCK_INTERVAL_MS",
    "SIM_INTERVAL_MS"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "type-check": {
      "outputs": []
    },
    "test": {
      "outputs": ["coverage/**"],
      "dependsOn": ["^build"]
    }
  }
}
